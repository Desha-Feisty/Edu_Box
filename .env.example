# ============================================
# EduBox — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================

# Backend
# -------
PORT=3000

# MongoDB connection string.
# Docker Compose defaults to mongodb://mongodb:27017/edubox (the mongodb container).
# Set this to override, e.g. for Atlas: mongodb+srv://user:pass@cluster.mongodb.net/edubox
MONGODB_URI=mongodb://localhost:27017/edubox

# JWT_SECRET=<generate a strong secret: openssl rand -base64 32>
JWT_SECRET=change-me-to-a-random-secret
JWT_LIFETIME=1h
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_LIFETIME=7d

# Gemini AI (for AI-powered grading and question generation)
# GEMINI_API_KEY=<your Gemini API key>
GEMINI_API_KEY=

# Upstash Redis (for caching admin analytics — optional, gracefully skipped if unset)
# UPSTASH_REDIS_REST_URL=<your Upstash URL>
# UPSTASH_REDIS_REST_TOKEN=<your Upstash token>
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
